pipeline {
  agent any

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install Dependencies') {
      steps {
        dir('app') {
          sh 'npm ci'
        }
      }
    }

    stage('Run Tests') {
      steps {
        dir('app') {
          sh 'npm test -- --ci --watchAll=false || npm test -- --ci || true'
        }
      }
    }

    stage('Build Docker Image') {
      steps {
        sh 'docker build -f docker/Dockerfile -t legacy-devops-app:${BUILD_NUMBER} .'
      }
    }
  }

  post {
    success {
      echo 'Jenkins pipeline completed successfully.'
    }
    failure {
      echo 'Pipeline failed. Check stage logs for details.'
    }
  }
}
